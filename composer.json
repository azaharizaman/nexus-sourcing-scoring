{
    "name": "nexus/sourcing-scoring",
    "description": "Scoring engine for vendor evaluation and sourcing analysis",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\SourcingScoring\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\SourcingScoring\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
